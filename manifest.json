{
  "manifest_version": 3,
  "name": "Arca Img Extension",
  "version": "1.0.4",
  "description": "Preview and Download Arca.live images on hover.",
  "permissions": [
    "storage",
    "downloads"
  ],
  "icons": {
    "16": "arca_img.png",
    "48": "arca_img.png",
    "128": "arca_img.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://arca.live/*",
        "*://*.arca.live/*",
        "*://kone.gg/*",
        "*://*.kone.gg/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ]
}