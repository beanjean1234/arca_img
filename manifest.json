{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.6",
  "description": "__MSG_appDesc__",
  "default_locale": "ko",
  "permissions": [
    "storage",
    "downloads"
  ],
  "icons": {
    "16": "arca_img.png",
    "48": "arca_img.png",
    "128": "arca_img.png"
  },
  "action": {
    "default_title": "__MSG_appName__",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "arca_img.png",
      "48": "arca_img.png",
      "128": "arca_img.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://arca.live/*",
        "*://*.arca.live/*",
        "*://kone.gg/*",
        "*://*.kone.gg/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ]
}
